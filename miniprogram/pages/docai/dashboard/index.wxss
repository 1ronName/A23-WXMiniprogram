.dashboard-hero {
  padding-bottom: 36rpx;
}

.dashboard-chip-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.dashboard-hero-btn {
  min-width: 188rpx;
}

.dashboard-hero .outline-btn {
  color: #fff8ef;
  border-color: rgba(255, 255, 255, 0.28);
  background: rgba(255, 255, 255, 0.12);
}

.dashboard-hero-btn--light {
  background: rgba(255, 255, 255, 0.18);
  color: #fff8ef;
}

.dashboard-grid {
  margin-top: 20rpx;
}

.dashboard-metric {
  box-shadow: none;
}

.dashboard-metric--primary {
  background: linear-gradient(180deg, #ffffff 0%, #edf2ff 100%);
}

.dashboard-metric--cool {
  background: linear-gradient(180deg, #ffffff 0%, #eef8ff 100%);
}

.dashboard-metric--warm {
  background: linear-gradient(180deg, #ffffff 0%, #fff5ea 100%);
}

.dashboard-metric--plain {
  background: linear-gradient(180deg, #ffffff 0%, #f4f6fb 100%);
}
