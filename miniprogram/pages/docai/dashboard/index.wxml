<view class="doc-page">
  <view class="page-shell">
    <view class="panel rise-in">
      <view class="section-head">
        <view>
          <view class="section-title">核心数据</view>
          <view class="section-subtitle">先确认资料规模，再执行填表或问答。</view>
        </view>
        <button class="solid-btn inline-btn dashboard-upload-btn" bindtap="goDocuments">去上传文件</button>
      </view>

      <view class="metric-grid dashboard-grid">
        <view class="metric-card dashboard-metric dashboard-metric--primary">
          <view class="metric-value">{{stats.total}}</view>
          <view class="metric-label">文档总数</view>
          <view class="metric-note">当前账号下全部资料</view>
        </view>
        <view class="metric-card dashboard-metric dashboard-metric--cool">
          <view class="metric-value">{{stats.docx + stats.xlsx}}</view>
          <view class="metric-label">可填表资料</view>
          <view class="metric-note">Word / Excel</view>
        </view>
        <view class="metric-card dashboard-metric dashboard-metric--warm">
          <view class="metric-value">{{stats.txt + stats.md}}</view>
          <view class="metric-label">文本资料</view>
          <view class="metric-note">TXT / Markdown</view>
        </view>
        <view class="metric-card dashboard-metric dashboard-metric--plain">
          <view class="metric-value">{{sourceDocCount}}</view>
          <view class="metric-label">来源文档</view>
          <view class="metric-note">用于智能填表的数据池</view>
        </view>
      </view>
    </view>

    <view class="panel rise-in">
      <view class="section-head">
        <view>
          <view class="section-title">智能填表</view>
          <view class="section-subtitle">选择模板后直接生成预览。</view>
        </view>
        <view class="pill">最近更新 {{lastUpdated}}</view>
      </view>

      <view class="hero-actions dashboard-fill-actions">
        <button class="solid-btn inline-btn" bindtap="chooseTemplate">选择模板</button>
        <button class="outline-btn inline-btn dashboard-fill-outline" loading="{{loading}}" bindtap="startFill">开始预览</button>
      </view>

      <view class="autofill-status-grid">
        <view class="autofill-status-card">
          <view class="autofill-status-label">已选模板</view>
          <view class="autofill-status-value">{{templateName || '暂未选择模板文件'}}</view>
        </view>
        <view class="autofill-status-card">
          <view class="autofill-status-label">当前状态</view>
          <view class="autofill-status-value">{{templateStatusText}}</view>
        </view>
      </view>

      <view class="autofill-note">
        提示：来源文档不足时，请先到文档中心上传资料。
      </view>

      <view class="dashboard-fill-result" wx:if="{{resultReady}}">
        <view class="metric-grid autofill-metrics">
          <view class="metric-card dashboard-metric dashboard-metric--primary">
            <view class="metric-value">{{resultMeta.filledCount}}</view>
            <view class="metric-label">已填字段</view>
            <view class="metric-note">自动回填成功</view>
          </view>
          <view class="metric-card dashboard-metric dashboard-metric--cool">
            <view class="metric-value">{{resultMeta.blankCount}}</view>
            <view class="metric-label">待补字段</view>
            <view class="metric-note">需人工确认</view>
          </view>
          <view class="metric-card dashboard-metric dashboard-metric--warm">
            <view class="metric-value">{{resultMeta.totalSlots}}</view>
            <view class="metric-label">总字段数</view>
            <view class="metric-note">本次模板识别</view>
          </view>
          <view class="metric-card dashboard-metric dashboard-metric--plain">
            <view class="metric-value">{{resultMeta.fillTimeMs}}ms</view>
            <view class="metric-label">处理耗时</view>
            <view class="metric-note">服务端统计</view>
          </view>
        </view>

        <view class="autofill-result-meta">
          <view class="autofill-result-item">模板名称：{{resultMeta.templateName || templateName || '未返回'}}</view>
          <view class="autofill-result-item">结果文件大小：{{resultMeta.fileSizeText}}</view>
        </view>

        <text class="autofill-result-text">{{resultText}}</text>
      </view>
    </view>

  </view>
</view>
