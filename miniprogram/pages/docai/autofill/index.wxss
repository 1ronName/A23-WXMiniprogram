.autofill-entry-metrics,
.autofill-metrics {
  margin-top: 18rpx;
}

.autofill-hero-card {
  position: relative;
  overflow: hidden;
}

.autofill-hero-card::after {
  content: '';
  position: absolute;
  right: -50rpx;
  top: -30rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0) 72%);
}

.hero-meta-row {
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hero-meta-pill {
  position: relative;
  z-index: 1;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 248, 239, 0.92);
  font-size: 22rpx;
  line-height: 44rpx;
}

.hero-meta-pill--soft {
  background: rgba(255, 255, 255, 0.09);
}

.picker-toolbar,
.template-actions,
.result-actions {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.selected-list {
  margin-top: 18rpx;
}

.selected-title {
  font-size: 24rpx;
  color: #60708a;
}

.source-toolbar {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.source-toolbar-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.source-upload-btn {
  flex: 1;
  min-width: 220rpx;
}

.source-picker-btn {
  flex: 1;
  min-width: 220rpx;
}

.source-count-card {
  flex: 1;
  min-width: 0;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #eef4ff 100%);
  border: 1rpx solid #dce6fa;
}

.source-count-value {
  font-size: 42rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #1845b8;
}

.source-count-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #46556d;
}

.source-count-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #73829a;
}

.selected-chip-list,
.result-source-list {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.selected-chip,
.result-source-chip {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #edf3ff;
  color: #1f58ef;
  font-size: 22rpx;
  line-height: 48rpx;
}

.selected-chip-text {
  max-width: 340rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selected-chip-remove {
  margin-left: 10rpx;
  font-size: 28rpx;
  line-height: 1;
}

.selected-source-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.selected-source-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f5f8ff 100%);
  border: 1rpx solid #dfe7f6;
}

.selected-source-main {
  flex: 1;
  min-width: 0;
}

.selected-source-name {
  font-size: 27rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #1d2940;
  word-break: break-word;
}

.selected-source-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6b7b94;
}

.selected-source-side {
  min-width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.selected-source-stage {
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #eef3fc;
  color: #5c6b81;
  font-size: 20rpx;
  line-height: 40rpx;
  white-space: nowrap;
}

.selected-source-stage--warning {
  background: #fff1cc;
  color: #996700;
}

.selected-source-stage--info {
  background: #e7f0ff;
  color: #315fb0;
}

.selected-source-stage--success {
  background: #ddf8e8;
  color: #23734b;
}

.selected-source-stage--danger {
  background: #ffe2de;
  color: #c04d3a;
}

.selected-source-remove {
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #d05a32;
}

.source-empty-state {
  margin-top: 12rpx;
  padding: 44rpx 20rpx;
}

.picker-doc-list,
.decision-list,
.stage-list,
.run-progress-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.picker-doc-card,
.decision-card,
.stage-card,
.template-card,
.run-textarea-card,
.result-meta-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #f9fbff;
  border: 1rpx solid #dde5f4;
}

.picker-doc-card--warning,
.stage-card--warning {
  background: #fffaf0;
  border-color: #f1deaf;
}

.picker-doc-card--info,
.stage-card--info {
  background: #f3f7ff;
  border-color: #cddfff;
}

.picker-doc-card--success,
.stage-card--success {
  background: #f4fff8;
  border-color: #cde9d9;
}

.picker-doc-card--danger {
  background: #fff4f3;
  border-color: #f0d1cc;
}

.picker-doc-head,
.decision-head,
.stage-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.picker-doc-main {
  flex: 1;
  min-width: 0;
}

.picker-doc-title,
.decision-title,
.stage-title,
.template-card-value {
  font-size: 28rpx;
  line-height: 1.5;
  color: #1c2942;
  font-weight: 700;
  word-break: break-word;
}

.picker-doc-meta,
.picker-doc-desc,
.stage-desc,
.template-card-label,
.template-card-note,
.result-meta-item,
.decision-value,
.decision-reason,
.autofill-web-label,
.autofill-web-note {
  font-size: 24rpx;
  line-height: 1.7;
  color: #5f6e84;
}

.picker-doc-meta {
  margin-top: 8rpx;
}

.picker-doc-desc,
.stage-desc,
.decision-value {
  margin-top: 12rpx;
}

.picker-doc-stage,
.decision-confidence {
  min-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef3fc;
  color: #5c6b81;
  font-size: 22rpx;
  line-height: 46rpx;
  white-space: nowrap;
}

.picker-doc-stage--warning {
  background: #fff1cc;
  color: #996700;
}

.picker-doc-stage--info {
  background: #e7f0ff;
  color: #315fb0;
}

.picker-doc-stage--success,
.decision-confidence {
  background: #ddf8e8;
  color: #23734b;
}

.picker-doc-stage--danger {
  background: #ffe2de;
  color: #c04d3a;
}

.picker-doc-btn,
.run-submit-btn,
.autofill-web-btn {
  width: 100%;
}

.picker-doc-btn {
  margin-top: 18rpx;
}

.template-card,
.run-textarea-card,
.result-meta-card,
.autofill-web-card {
  margin-top: 18rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6faff 100%);
  border-color: #e1e9f7;
}

.template-card-note,
.autofill-web-note {
  margin-top: 12rpx;
}

.run-textarea {
  width: 100%;
  min-height: 220rpx;
  margin-top: 14rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f7faff;
  color: #22324d;
  font-size: 26rpx;
  line-height: 1.7;
}

.run-textarea-count {
  margin-top: 10rpx;
  text-align: right;
  font-size: 22rpx;
  color: #75839b;
}

.run-progress-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 54rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f2f6fd;
}

.run-progress-item--active {
  background: #e8f0ff;
}

.run-progress-item--done {
  background: #e3f8ec;
}

.run-progress-dot,
.stage-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #92a0b8;
}

.run-progress-item--active .run-progress-dot {
  background: #1d57f2;
}

.run-progress-item--done .run-progress-dot {
  background: #26a269;
}

.run-progress-text {
  font-size: 24rpx;
  color: #425168;
}

.run-progress-note,
.run-error-note,
.autofill-result-text {
  display: block;
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
}

.run-progress-note {
  background: #f4f8ff;
  color: #38537f;
}

.run-error-note {
  background: #fff2ef;
  color: #c5553f;
}

.autofill-result-text {
  background: #f5f8fd;
  color: #334155;
}

.run-submit-btn {
  margin-top: 18rpx;
}

.result-action-btn {
  flex: 1;
  min-width: calc(50% - 6rpx);
}

.autofill-web-card {
  background: linear-gradient(180deg, #f8fbff 0%, #eef5ff 100%);
  border-color: #d7e4fb;
}

.autofill-web-value {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #173256;
  font-weight: 700;
  word-break: break-all;
}
