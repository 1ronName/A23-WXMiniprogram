.picker-metrics {
  margin-top: 18rpx;
}

.picker-toolbar {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.picker-toolbar--spread {
  justify-content: space-between;
}

.picker-doc-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.picker-doc-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #f9fbff;
  border: 1rpx solid #dde5f4;
}

.picker-doc-card--warning {
  background: #fffaf0;
  border-color: #f1deaf;
}

.picker-doc-card--info {
  background: #f3f7ff;
  border-color: #cddfff;
}

.picker-doc-card--success {
  background: #f4fff8;
  border-color: #cde9d9;
}

.picker-doc-card--danger {
  background: #fff4f3;
  border-color: #f0d1cc;
}

.picker-doc-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.picker-doc-main {
  flex: 1;
  min-width: 0;
}

.picker-doc-title {
  font-size: 28rpx;
  line-height: 1.5;
  color: #19263f;
  font-weight: 700;
  word-break: break-word;
}

.picker-doc-meta {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #66748b;
}

.picker-doc-stage {
  min-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef3fc;
  color: #5c6b81;
  font-size: 22rpx;
  line-height: 46rpx;
  white-space: nowrap;
}

.picker-doc-stage--warning {
  background: #fff1cc;
  color: #996700;
}

.picker-doc-stage--info {
  background: #e7f0ff;
  color: #315fb0;
}

.picker-doc-stage--success {
  background: #ddf8e8;
  color: #23734b;
}

.picker-doc-stage--danger {
  background: #ffe2de;
  color: #c04d3a;
}

.picker-doc-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5e6f86;
}

.picker-doc-btn {
  margin-top: 18rpx;
  width: 100%;
}

.picker-bottom-btn {
  width: 100%;
}

.template-source-preview {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.template-source-chip {
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #edf3ff;
  color: #1f58ef;
  font-size: 22rpx;
  line-height: 48rpx;
}

.template-source-more {
  width: 100%;
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6a778d;
}

.template-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef5ff 100%);
  border: 1rpx solid #d7e4fb;
}

.template-card-label {
  font-size: 22rpx;
  color: #66748b;
}

.template-card-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #173256;
  font-weight: 700;
  word-break: break-all;
}

.template-card-note {
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.75;
  color: #5f6e84;
}

.template-actions {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
