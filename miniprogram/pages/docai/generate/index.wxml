<view class="page">
  <view class="card">
    <view class="label">公文类型</view>
    <picker mode="selector" range="{{docTypes}}" value="{{docTypeIndex}}" bindchange="onDocTypeChange">
      <view class="picker">{{docTypes[docTypeIndex]}}</view>
    </picker>

    <view class="label">标题</view>
    <input class="input" placeholder="例如：关于开展XX工作的通知" value="{{title}}" bindinput="onTitleInput" />

    <view class="label">需求描述</view>
    <textarea class="textarea" maxlength="2000" value="{{requirement}}" bindinput="onRequirementInput" placeholder="描述主题、背景、目标和关键要点" />

    <button class="btn" type="primary" loading="{{generating}}" bindtap="generate">生成内容</button>
    <button class="btn" loading="{{polishing}}" bindtap="polish">润色优化</button>
  </view>

  <view class="card" wx:if="{{generatedContent}}">
    <view class="label">生成结果</view>
    <textarea class="textarea output" value="{{generatedContent}}" bindinput="onContentEdit" />

    <view class="actions">
      <button size="mini" bindtap="copyContent">复制</button>
      <button size="mini" bindtap="clearContent">清空</button>
    </view>
  </view>
</view>
