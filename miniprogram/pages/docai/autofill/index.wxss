.autofill-hero-outline {
  color: #fff8ef;
  border-color: rgba(255, 255, 255, 0.28);
  background: rgba(255, 255, 255, 0.12);
}

.autofill-status-grid {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.autofill-status-card {
  padding: 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6f9ff 100%);
  border: 1rpx solid #e3eaf8;
}

.autofill-status-label {
  font-size: 22rpx;
  color: #6a7387;
}

.autofill-status-value {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.55;
  color: #1c2942;
  font-weight: 700;
  word-break: break-all;
}

.autofill-note {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #687287;
}

.autofill-metrics {
  margin-top: 18rpx;
}

.autofill-result-meta {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.autofill-result-item {
  font-size: 24rpx;
  color: #5f687b;
}

.autofill-result-text {
  display: block;
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  color: #334155;
  font-size: 25rpx;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-word;
}
