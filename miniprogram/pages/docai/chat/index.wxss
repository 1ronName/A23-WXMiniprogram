.page {
  min-height: 100vh;
  background: #f5f7fb;
  display: flex;
  flex-direction: column;
}

.doc-context {
  margin: 16rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.doc-name {
  font-size: 24rpx;
  color: #334155;
  max-width: 530rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.messages {
  flex: 1;
  padding: 0 16rpx 16rpx;
  box-sizing: border-box;
}

.msg {
  margin-top: 14rpx;
  display: flex;
}

.msg.user {
  justify-content: flex-end;
}

.msg.ai {
  justify-content: flex-start;
}

.bubble {
  max-width: 78%;
  font-size: 26rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
  padding: 16rpx;
  border-radius: 14rpx;
}

.msg.user .bubble {
  background: #336dff;
  color: #ffffff;
}

.msg.ai .bubble {
  background: #ffffff;
  color: #1f2937;
}

.input-bar {
  padding: 12rpx 16rpx 18rpx;
  box-sizing: border-box;
  background: #ffffff;
  display: flex;
  gap: 12rpx;
  align-items: flex-end;
}

.input {
  flex: 1;
  min-height: 72rpx;
  max-height: 180rpx;
  border: 1rpx solid #dbe4ff;
  border-radius: 12rpx;
  padding: 12rpx;
  font-size: 26rpx;
  background: #f8faff;
}

.send {
  margin: 0;
  border-radius: 12rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #356cff 0%, #2251cb 100%);
  color: #ffffff;
  border: 0;
}

.secondary-btn {
  margin: 0;
  background: #eff4ff;
  color: #2d55cf;
  border: 1rpx solid #cddcff;
}

.primary-btn::after,
.secondary-btn::after {
  border: 0;
}
