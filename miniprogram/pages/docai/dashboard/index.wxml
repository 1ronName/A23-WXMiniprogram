<view class="page">
  <view class="hero">
    <view class="hero-head">
      <view class="hero-title">DocAI 智能文档处理系统</view>
      <button class="logout-btn" size="mini" bindtap="logout">退出登录</button>
    </view>
    <view class="hero-desc">整合 AI 大模型，支持文档管理、信息提取、智能填表与对话问答</view>
  </view>

  <view class="stats-grid">
    <view class="stat-card">
      <view class="stat-value">{{stats.total}}</view>
      <view class="stat-label">总文档数</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{stats.docx}}</view>
      <view class="stat-label">Word 文档</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{stats.xlsx}}</view>
      <view class="stat-label">Excel 文档</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{stats.txt + stats.md}}</view>
      <view class="stat-label">文本文件</view>
    </view>
  </view>

  <view class="section-title">核心流程</view>
  <view class="flow-box">
    <view class="flow-item">
      <view class="flow-index">1</view>
      <view class="flow-content">
        <view class="flow-title">上传文档</view>
        <view class="flow-desc">在文档页上传待处理资料</view>
      </view>
    </view>
    <view class="flow-item">
      <view class="flow-index">2</view>
      <view class="flow-content">
        <view class="flow-title">AI 提取信息</view>
        <view class="flow-desc">自动解析文档并抽取关键字段</view>
      </view>
    </view>
    <view class="flow-item">
      <view class="flow-index">3</view>
      <view class="flow-content">
        <view class="flow-title">上传模板</view>
        <view class="flow-desc">选择 Word/Excel 模板进行匹配</view>
      </view>
    </view>
    <view class="flow-item">
      <view class="flow-index">4</view>
      <view class="flow-content">
        <view class="flow-title">自动填表</view>
        <view class="flow-desc">根据提取数据智能完成填写</view>
      </view>
    </view>
    <view class="flow-item">
      <view class="flow-index">5</view>
      <view class="flow-content">
        <view class="flow-title">下载结果</view>
        <view class="flow-desc">预览并导出最终文档</view>
      </view>
    </view>
  </view>
</view>
