page {
  background: #f3f5f7;
}

.dashboard-page {
  min-height: 100vh;
  padding-left: 0;
  padding-right: 0;
  background: #f3f5f7;
}

.dashboard-page .panel {
  border-radius: 28rpx;
  border: none;
  box-shadow: none;
}

.dashboard-grid {
  margin-top: 16rpx;
}

.dashboard-info-head {
  align-items: center;
}

.dashboard-info-panel .dashboard-grid {
  margin-top: 12rpx;
  flex-wrap: nowrap;
  gap: 8rpx;
  justify-content: flex-start;
}

.dashboard-info-panel .dashboard-upload-btn {
  min-width: 160rpx;
}

.dashboard-info-panel .dashboard-metric {
  width: calc((100% - 24rpx) / 4);
  min-height: 112rpx;
  padding: 12rpx 10rpx;
  border-radius: 14rpx;
  border-color: #e5ebf5;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
}

.dashboard-info-panel .dashboard-metric--primary,
.dashboard-info-panel .dashboard-metric--cool,
.dashboard-info-panel .dashboard-metric--warm,
.dashboard-info-panel .dashboard-metric--plain {
  background: #ffffff;
}

.dashboard-info-panel .metric-value {
  font-size: 34rpx;
  line-height: 1.15;
  color: #1c54ea;
}

.dashboard-info-panel .metric-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.35;
  color: #4f5c74;
}

.dashboard-metric {
  box-shadow: none;
}

.dashboard-metric--primary {
  background: #edf2ff;
}

.dashboard-metric--cool {
  background: #eef8ff;
}

.dashboard-metric--warm {
  background: #fff5ea;
}

.dashboard-metric--plain {
  background: #f4f6fb;
}

.dashboard-fill-actions {
  margin-top: 14rpx;
}

.dashboard-fill-outline {
  color: #fff8ef;
  border: 1rpx solid currentColor;
  background: rgba(255, 255, 255, 0.12);
}

.dashboard-fill-outline[disabled] {
  opacity: 0.45;
}

.dashboard-fill-result {
  margin-top: 18rpx;
}

.dashboard-upload-btn {
  min-width: 188rpx;
}

.autofill-status-grid {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.autofill-status-card {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f6f9ff;
  border: 1rpx solid #e3eaf8;
}

.autofill-status-label {
  font-size: 22rpx;
  color: #6a7387;
}

.autofill-status-value {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.55;
  color: #1c2942;
  font-weight: 700;
  word-break: break-all;
}

.autofill-note {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #687287;
}

.autofill-metrics {
  margin-top: 18rpx;
}

.autofill-result-meta {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.autofill-result-item {
  font-size: 24rpx;
  color: #5f687b;
}

.autofill-result-text {
  display: block;
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f5f8fd;
  color: #334155;
  font-size: 25rpx;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-word;
}

